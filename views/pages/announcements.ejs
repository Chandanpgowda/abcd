<%- include('../partials/header') %>

<h1 class="text-4xl font-bold text-center py-10 fade-in-on-scroll">Announcements</h1>

<div class="container mx-auto p-6 max-w-3xl">
  <div class="space-y-6 fade-in-on-scroll">
    <% if (announcements && announcements.length > 0) { %>
      <% announcements.forEach((ann, index) => { %>
        <div class="bg-gray-800 p-6 rounded-lg hover:shadow-2xl transition hover:scale-[1.02] hover-grow fade-in-on-scroll delay-<%= index+1 %>">
          <h2 class="text-2xl font-bold"><%= ann.title %></h2>
          <p class="text-gray-300 mt-3 whitespace-pre-line"><%= ann.content %></p>
          <p class="text-sm text-blue-300 mt-4"><%= new Date(ann.createdAt).toLocaleDateString() %></p>
        </div>
      <% }) %>
    <% } else { %>
      <p class="text-gray-400 text-center">No announcements yet.</p>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>