<%- include('../partials/header') %>

<div class="container mx-auto p-6 max-w-2xl">
  <h1 class="text-4xl font-bold text-center py-6">Register for Event</h1>

  <!-- Flash messages -->
  <% if (error_msg && error_msg.length > 0) { %>
    <div class="bg-red-600 text-white p-3 rounded mb-4"><%= error_msg %></div>
  <% } %>
  <% if (success_msg && success_msg.length > 0) { %>
    <div class="bg-green-600 text-white p-3 rounded mb-4"><%= success_msg %></div>
  <% } %>

  <div class="bg-gray-800 p-8 rounded-lg mb-8">
    <h2 class="text-2xl font-bold mb-2"><%= event.title %></h2>
    <p class="text-gray-400 mb-4"><%= event.description %></p>
    <p class="text-blue-300 mb-6"><%= new Date(event.date).toLocaleDateString() %></p>

    <form action="/events/register/<%= event._id %>" method="POST" class="space-y-4">
      <div>
        <label class="block text-gray-300 mb-2">Full Name</label>
        <input type="text" name="name" required class="w-full p-3 rounded bg-gray-700 text-white border border-gray-600 focus:outline-none focus:border-blue-500">
      </div>
      <div>
        <label class="block text-gray-300 mb-2">Email Address</label>
        <input type="email" name="email" required class="w-full p-3 rounded bg-gray-700 text-white border border-gray-600 focus:outline-none focus:border-blue-500">
      </div>
      <div>
        <label class="block text-gray-300 mb-2">Phone Number</label>
        <input type="tel" name="phone" required class="w-full p-3 rounded bg-gray-700 text-white border border-gray-600 focus:outline-none focus:border-blue-500">
      </div>
      <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded transition">Register Now</button>
      <a href="/events" class="ml-4 text-gray-400 hover:text-white">Cancel</a>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>