<%- include('../partials/header') %>

<h1 class="text-4xl font-bold text-center py-10 fade-in-on-scroll">Gallery</h1>

<div class="container mx-auto p-6">
  <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-4 fade-in-on-scroll">
    <% if (images && images.length > 0) { %>
      <% images.forEach((image, index) => { %>
        <div class="bg-gray-800 rounded-lg overflow-hidden hover:shadow-2xl transition transform hover:scale-105 hover-grow fade-in-on-scroll delay-<%= index+1 %>">
          <img src="<%= image.image %>" alt="<%= image.title %>" loading="lazy" class="w-full h-48 object-cover">
          <div class="p-3">
            <p class="font-semibold"><%= image.title %></p>
            <p class="text-sm text-gray-400"><%= new Date(image.uploadedAt).toLocaleDateString() %></p>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p class="text-gray-400 col-span-full text-center">No images in gallery yet.</p>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>