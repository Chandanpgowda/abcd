<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TechSpark</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- custom dark/light theme styles -->
  <style>
    /* Base styles */
    html {
      scroll-behavior: smooth;
    }
    body {
      transition: background-color 0.3s, color 0.3s;
    }
    /* Dark mode (default) */
    body.dark {
      background-color: #0a192f;
      color: white;
    }
    body.dark .bg-deep-blue { background-color: #0a192f; }
    body.dark .bg-gray-800 { background-color: #1f2937; }
    body.dark .text-gray-300 { color: #d1d5db; }
    
    /* Light mode */
    body.light {
      background-color: #f9fafb;
      color: #111827;
    }
    body.light .bg-deep-blue { background-color: #f9fafb; }
    body.light .bg-gray-800 { background-color: #e5e7eb; }
    body.light .text-gray-300 { color: #4b5563; }
    body.light .border-gray-700 { border-color: #d1d5db; }
    
    /* Animations */
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in {
      animation: fadeIn 1s ease-out forwards;
    }
    .delay-1 { animation-delay: 0.2s; }
    .delay-2 { animation-delay: 0.4s; }
    .delay-3 { animation-delay: 0.6s; }

    /* Hover effects */
    .hover-grow {
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .hover-grow:hover {
      transform: scale(1.02);
      box-shadow: 0 10px 25px -5px rgba(0,0,0,0.5);
    }

    /* Responsive font sizes */
    @media (max-width: 640px) {
      h1 { font-size: 2rem !important; }
      h2 { font-size: 1.5rem !important; }
    }
  </style>
</head>
<body class="dark"> <!-- default dark mode -->
  <nav class="p-5 flex justify-between items-center border-b border-gray-700">
    <div class="flex items-center space-x-2">
      <img src="/logo.png" alt="TechSpark Logo" class="h-10 w-10">
      <span class="text-2xl font-bold">TechSpark</span>
    </div>
    <div class="space-x-6 hidden md:block"> <!-- hide on mobile, show on medium+ -->
      <a href="/" class="hover:text-blue-300">Home</a>
      <a href="/about" class="hover:text-blue-300">About</a>
      <a href="/events" class="hover:text-blue-300">Events</a>
      <a href="/gallery" class="hover:text-blue-300">Gallery</a>
      <a href="/team" class="hover:text-blue-300">Team</a>
      <a href="/announcements" class="hover:text-blue-300">Announcements</a>
      <a href="/contact" class="hover:text-blue-300">Contact</a>
    </div>
    <div class="flex items-center space-x-3">
      <!-- Dark mode toggle switch -->
      <button id="darkModeToggle" class="bg-gray-700 px-3 py-1 rounded flex items-center space-x-2 hover:bg-gray-600">
        <span class="text-sm">🌙 Dark</span>
      </button>
      <% if (session && session.user) { %>
        <span class="text-sm text-gray-300 hidden sm:inline"><%= session.user.name %></span>
        <a href="/logout" class="bg-red-600 px-3 py-1 rounded text-sm hover:bg-red-700">Logout</a>
      <% } else { %>
        <a href="/login" class="bg-blue-600 px-3 py-1 rounded text-sm hover:bg-blue-700">Login</a>
      <% } %>
    </div>
  </nav>
  <main class="container mx-auto p-5">