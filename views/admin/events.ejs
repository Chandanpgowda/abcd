<%- include('../partials/header') %>

<div class="container mx-auto p-6">
  <div class="flex justify-between items-center mb-6">
    <div class="flex items-center space-x-4">
      <a href="/admin" class="text-blue-400 hover:text-blue-300 text-lg">&larr; Back to Dashboard</a>
      <h1 class="text-3xl font-bold">Manage Events</h1>
    </div>
    <a href="/admin/events/new" class="bg-green-600 hover:bg-green-700 px-4 py-2 rounded">+ Add New Event</a>
  </div>

  <% if (success_msg && success_msg.length > 0) { %>
    <div class="bg-green-600 text-white p-3 rounded mb-4"><%= success_msg %></div>
  <% } %>
  <% if (error_msg && error_msg.length > 0) { %>
    <div class="bg-red-600 text-white p-3 rounded mb-4"><%= error_msg %></div>
  <% } %>

  <div class="overflow-x-auto">
    <table class="w-full bg-gray-800 rounded-lg">
      <thead>
        <tr class="border-b border-gray-700">
          <th class="p-3 text-left">Title</th>
          <th class="p-3 text-left">Type</th>
          <th class="p-3 text-left">Date</th>
          <th class="p-3 text-left">Google Form</th>
          <th class="p-3 text-left">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% events.forEach(event => { %>
          <tr class="border-b border-gray-700 hover:bg-gray-700">
            <td class="p-3"><%= event.title %></td>
            <td class="p-3">
              <span class="px-2 py-1 rounded text-xs <%= event.type === 'upcoming' ? 'bg-blue-600' : 'bg-gray-600' %>">
                <%= event.type %>
              </span>
            </td>
            <td class="p-3"><%= new Date(event.date).toLocaleDateString() %></td>
            <td class="p-3">
              <% if (event.googleFormUrl) { %>
                <a href="<%= event.googleFormUrl %>" target="_blank" class="text-blue-400 hover:underline">View Form</a>
              <% } else { %>
                <span class="text-gray-500">None</span>
              <% } %>
            </td>
            <td class="p-3">
              <a href="/admin/events/edit/<%= event._id %>" class="text-blue-400 hover:text-blue-300 mr-3">Edit</a>
              <form action="/admin/events/delete/<%= event._id %>" method="POST" class="inline">
                <button type="submit" class="text-red-500 hover:text-red-700" onclick="return confirm('Are you sure?')">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>