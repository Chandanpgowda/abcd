<%- include('../partials/header') %>

<div class="container mx-auto p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold">Gallery Management</h1>
    <a href="/admin/gallery/new" class="bg-green-600 hover:bg-green-700 px-4 py-2 rounded">+ Add New Image</a>
  </div>

  <% if (success_msg && success_msg.length > 0) { %>
    <div class="bg-green-600 text-white p-3 rounded mb-4"><%= success_msg %></div>
  <% } %>
  <% if (error_msg && error_msg.length > 0) { %>
    <div class="bg-red-600 text-white p-3 rounded mb-4"><%= error_msg %></div>
  <% } %>

  <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-4">
    <% images.forEach(image => { %>
      <div class="bg-gray-800 rounded-lg overflow-hidden">
        <img src="<%= image.image %>" alt="<%= image.title %>" class="w-full h-48 object-cover">
        <div class="p-3">
          <p class="font-semibold"><%= image.title %></p>
          <p class="text-sm text-gray-400"><%= new Date(image.uploadedAt).toLocaleDateString() %></p>
          <div class="flex justify-between mt-2">
            <a href="/admin/gallery/edit/<%= image._id %>" class="text-blue-400 hover:text-blue-300 text-sm">Edit</a>
            <form action="/admin/gallery/delete/<%= image._id %>" method="POST" class="inline">
              <button type="submit" class="text-red-500 hover:text-red-700 text-sm" onclick="return confirm('Delete this image?')">Delete</button>
            </form>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<%- include('../partials/footer') %>