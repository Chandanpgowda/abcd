<%- include('../partials/header') %>

<div class="max-w-2xl mx-auto bg-gray-800 p-8 rounded-lg mt-10">
  <h2 class="text-2xl font-bold mb-6">Edit Gallery Image</h2>
  
  <% if (error_msg && error_msg.length > 0) { %>
    <div class="bg-red-600 text-white p-3 rounded mb-4"><%= error_msg %></div>
  <% } %>
  <% if (success_msg && success_msg.length > 0) { %>
    <div class="bg-green-600 text-white p-3 rounded mb-4"><%= success_msg %></div>
  <% } %>

  <form action="/admin/gallery/edit/<%= image._id %>" method="POST" enctype="multipart/form-data">
    <div class="mb-4">
      <label class="block text-gray-300 mb-2">Image Title</label>
      <input type="text" name="title" value="<%= image.title %>" class="w-full p-3 rounded bg-gray-700 text-white border border-gray-600" required>
    </div>
    
    <div class="mb-4">
      <label class="block text-gray-300 mb-2">Current Image</label>
      <img src="<%= image.image %>" alt="<%= image.title %>" class="w-48 h-48 object-cover rounded mb-2">
      <label class="block text-gray-300 mb-2 mt-2">Replace Image (optional)</label>
      <input type="file" name="image" accept="image/*" class="w-full p-3 rounded bg-gray-700 text-white border border-gray-600">
    </div>
    
    <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded">Update Image</button>
    <a href="/admin/gallery" class="ml-4 text-gray-400 hover:text-white">Cancel</a>
  </form>
</div>

<%- include('../partials/footer') %>