<%- include('../partials/header') %>

<div class="max-w-2xl mx-auto bg-gray-800 p-8 rounded-lg mt-10">
  <div class="flex items-center space-x-4 mb-6">
    <a href="/admin/events" class="text-blue-400 hover:text-blue-300 text-lg">&larr; Back to Events</a>
    <h2 class="text-2xl font-bold">Add New Event</h2>
  </div>
  
  <% if (error_msg && error_msg.length > 0) { %>
    <div class="bg-red-600 text-white p-3 rounded mb-4"><%= error_msg %></div>
  <% } %>
  <% if (success_msg && success_msg.length > 0) { %>
    <div class="bg-green-600 text-white p-3 rounded mb-4"><%= success_msg %></div>
  <% } %>

  <form action="/admin/events" method="POST" enctype="multipart/form-data">
    <div class="mb-4">
      <label class="block text-gray-300 mb-2">Event Title</label>
      <input type="text" name="title" class="w-full p-3 rounded bg-gray-700 text-white border border-gray-600" required>
    </div>
    
    <div class="mb-4">
      <label class="block text-gray-300 mb-2">Description</label>
      <textarea name="description" rows="4" class="w-full p-3 rounded bg-gray-700 text-white border border-gray-600" required></textarea>
    </div>
    
    <div class="mb-4">
      <label class="block text-gray-300 mb-2">Event Type</label>
      <select name="type" class="w-full p-3 rounded bg-gray-700 text-white border border-gray-600">
        <option value="upcoming">Upcoming</option>
        <option value="past">Past</option>
      </select>
    </div>
    
    <div class="mb-4">
      <label class="block text-gray-300 mb-2">Event Date</label>
      <input type="date" name="date" class="w-full p-3 rounded bg-gray-700 text-white border border-gray-600" required>
    </div>
    
    <div class="mb-4">
      <label class="block text-gray-300 mb-2">Google Form Registration Link (optional)</label>
      <input type="url" name="googleFormUrl" class="w-full p-3 rounded bg-gray-700 text-white border border-gray-600" placeholder="https://forms.google.com/...">
    </div>
    
    <div class="mb-4">
      <label class="block text-gray-300 mb-2">Event Image (optional)</label>
      <input type="file" name="image" accept="image/*" class="w-full p-3 rounded bg-gray-700 text-white border border-gray-600">
    </div>
    
    <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded">Add Event</button>
    <a href="/admin/events" class="ml-4 text-gray-400 hover:text-white">Cancel</a>
  </form>
</div>

<%- include('../partials/footer') %>