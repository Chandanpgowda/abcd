<%- include('../partials/header') %>

<div class="container mx-auto p-6">
  <h1 class="text-4xl font-bold mb-8">Admin Dashboard</h1>
  
  <!-- Flash messages -->
  <% if (success_msg && success_msg.length > 0) { %>
    <div class="bg-green-600 text-white p-3 rounded mb-4"><%= success_msg %></div>
  <% } %>
  <% if (error_msg && error_msg.length > 0) { %>
    <div class="bg-red-600 text-white p-3 rounded mb-4"><%= error_msg %></div>
  <% } %>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <!-- Events Card -->
    <div class="bg-gray-800 p-6 rounded-lg shadow-lg">
      <h2 class="text-2xl font-semibold mb-4">Events</h2>
      <p class="text-gray-300 mb-4">Manage upcoming and past events</p>
      <a href="/admin/events" class="bg-blue-600 px-4 py-2 rounded inline-block hover:bg-blue-700">Manage Events</a>
    </div>
    
    <!-- Gallery Card -->
    <div class="bg-gray-800 p-6 rounded-lg shadow-lg">
      <h2 class="text-2xl font-semibold mb-4">Gallery</h2>
      <p class="text-gray-300 mb-4">Upload and manage photos</p>
      <a href="/admin/gallery" class="bg-blue-600 px-4 py-2 rounded inline-block hover:bg-blue-700">Manage Gallery</a>
    </div>
    
    <!-- Team Card -->
    <div class="bg-gray-800 p-6 rounded-lg shadow-lg">
      <h2 class="text-2xl font-semibold mb-4">Team</h2>
      <p class="text-gray-300 mb-4">Add/edit club members</p>
      <a href="/admin/team" class="bg-blue-600 px-4 py-2 rounded inline-block hover:bg-blue-700">Manage Team</a>
    </div>
    
    <!-- Announcements Card -->
    <div class="bg-gray-800 p-6 rounded-lg shadow-lg">
      <h2 class="text-2xl font-semibold mb-4">Announcements</h2>
      <p class="text-gray-300 mb-4">Post news and updates</p>
      <a href="/admin/announcements" class="bg-blue-600 px-4 py-2 rounded inline-block hover:bg-blue-700">Manage Announcements</a>
    </div>

    <!-- Messages Card -->
    <div class="bg-gray-800 p-6 rounded-lg shadow-lg">
      <h2 class="text-2xl font-semibold mb-4">Messages</h2>
      <p class="text-gray-300 mb-4">View contact form submissions</p>
      <a href="/admin/messages" class="bg-blue-600 px-4 py-2 rounded inline-block hover:bg-blue-700">View Messages</a>
    </div>

    <!-- Registrations Card -->
    <div class="bg-gray-800 p-6 rounded-lg shadow-lg">
      <h2 class="text-2xl font-semibold mb-4">Registrations</h2>
      <p class="text-gray-300 mb-4">View event sign-ups</p>
      <a href="/admin/registrations" class="bg-blue-600 px-4 py-2 rounded inline-block hover:bg-blue-700">View Registrations</a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>