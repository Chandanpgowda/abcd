<%- include('../partials/header') %>

<div class="max-w-md mx-auto bg-gray-800 p-8 rounded-lg mt-10">
  <h2 class="text-2xl font-bold mb-6 text-center">Login to TechSpark</h2>

  <% if (error && error.length > 0) { %>
    <div class="bg-red-600 text-white p-3 rounded mb-4"><%= error %></div>
  <% } %>
  <% if (success && success.length > 0) { %>
    <div class="bg-green-600 text-white p-3 rounded mb-4"><%= success %></div>
  <% } %>

  <form action="/login" method="POST">
    <div class="mb-4">
      <label class="block text-gray-300 mb-2">Email</label>
      <input type="email" name="email" value="<%= email %>" class="w-full p-3 rounded bg-gray-700 text-white border border-gray-600 focus:outline-none focus:border-blue-500" required>
    </div>
    <div class="mb-6">
      <label class="block text-gray-300 mb-2">Password</label>
      <input type="password" name="password" class="w-full p-3 rounded bg-gray-700 text-white border border-gray-600 focus:outline-none focus:border-blue-500" required>
    </div>
    <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded transition">Login</button>
  </form>
  <p class="text-center text-gray-400 mt-4">
    Don't have an account? <a href="/register" class="text-blue-400 hover:underline">Register</a>
  </p>
</div>

<%- include('../partials/footer') %>